{
    "mcpServers": {
        "plain": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://mcp.plain.com/mcp"
            ]
        },
        "slack": {
            "type": "http",
            "url": "https://mcp.slack.com/mcp"
        },
        "linear": {
            "type": "http",
            "url": "https://mcp.linear.app/mcp"
        },
        "notion": {
            "type": "http",
            "url": "https://mcp.notion.com/mcp"
        },
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "grafana": {
            "type": "http",
            "url": "https://mcp.grafana.com/mcp",
            "headers": {
                "X-Grafana-URL": "https://payrails.grafana.net"
            }
        },
        "temporal": {
            "command": "node",
            "args": [
                "${CLAUDE_PLUGIN_ROOT}/mcp-servers/temporal/index.mjs"
            ],
            "env": {
                "TEMPORAL_STAGING_MERCHANTS_URL": "https://status.temporal01.staging.aws.payrails.io",
                "TEMPORAL_STAGING_INTERNAL_URL": "https://status.temporal11.staging.aws.payrails.io",
                "TEMPORAL_PRODUCTION_URL": "https://status.temporal01.mixed-eu.aws.payrails.io",
                "TEMPORAL_CODEC_STAGING_MERCHANTS": "https://api.staging.payrails.io/merchant/temporal/codec/decode",
                "TEMPORAL_CODEC_STAGING_MERCHANTS_FALLBACK": "https://rc-api.staging.payrails.io/merchant/temporal/codec/decode",
                "TEMPORAL_CODEC_STAGING_MULTITENANT": "https://multitenant-api.staging.payrails.io/merchant/temporal/codec/decode",
                "TEMPORAL_CODEC_PRODUCTION": "https://api.payrails.io/merchant/temporal/codec/decode"
            }
        }
    }
}